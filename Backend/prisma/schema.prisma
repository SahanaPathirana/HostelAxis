// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  Student
  Admin
  Staff
}

enum VerificationStatus {
  Pending
  Verified
  Rejected
}

enum RoomType {
  Single
  Double
  Triple
  Quad
  Quint
}

enum BedType {
  Normal
  Bunk
}

enum FeePeriod {
  Monthly
  ThreeMonths
  SixMonths
  OneYear
}

enum ComplaintStatus {
  Open
  InProgress
  StaffNotified
  DoneByStaff
  Resolved
  Closed
}

enum ComplaintCategory {
  Electrical
  Plumbing
  Cleaning
  Security
  Internet
  Other
}

enum PaymentMethod {
  Cash
  OnlineTransfer
}

enum PaymentRequestStatus {
  Pending
  Approved
  Rejected
}

enum NotificationType {
  Complaint
  Payment
  Verification
  Visitor
  Notice
  General
}

enum BedRequestStatus {
  Pending
  Approved
  Rejected
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  fullName  String   @map("full_name")
  phone     String?
  role      Role     @default(Student)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student          Student?
  staff            Staff?
  notifications    Notification[]  @relation("UserNotifications")
  sentMessages     DirectMessage[] @relation("SentMessages")
  receivedMessages DirectMessage[] @relation("ReceivedMessages")
}

model Student {
  id                 String             @id @default(cuid())
  userId             String             @unique @map("user_id")
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  universityId       String             @unique @map("university_id")
  universityName     String             @map("university_name")
  verificationStatus VerificationStatus @default(Pending) @map("verification_status")
  currentFeePlanId   String?            @map("current_fee_plan_id")
  currentFeePlan     FeePlan?           @relation("CurrentFeePlan", fields: [currentFeePlanId], references: [id])
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  bed               Bed?
  payments          Payment[]
  complaints        Complaint[]
  paymentRequests   PaymentRequest[]
  visitors          VisitorLog[]
  allocationHistory BedAllocationHistory[]
  bedRequests       BedRequest[]
}

model Staff {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  department     String?
  whatsappNumber String   @map("whatsapp_number")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  complaints Complaint[]
}

model Room {
  id               String   @id @default(cuid())
  roomNumber       String   @unique @map("room_number")
  type             RoomType @default(Single)
  preferredBedType BedType? @map("preferred_bed_type")
  capacity         Int      @default(1)
  floor            Int
  hostelBlock      String   @map("hostel_block")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  beds Bed[]
}

model Bed {
  id         String    @id @default(cuid())
  bedNumber  String    @map("bed_number")
  bedType    BedType   @default(Normal) @map("bed_type")
  roomId     String    @map("room_id")
  room       Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  studentId  String?   @unique @map("student_id")
  student    Student?  @relation(fields: [studentId], references: [id])
  assignedAt DateTime? @map("assigned_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  history     BedAllocationHistory[]
  bedRequests BedRequest[]

  @@unique([roomId, bedNumber])
}

model BedAllocationHistory {
  id         String    @id @default(cuid())
  studentId  String    @map("student_id")
  student    Student   @relation(fields: [studentId], references: [id])
  bedId      String    @map("bed_id")
  bed        Bed       @relation(fields: [bedId], references: [id])
  assignedAt DateTime  @default(now()) @map("assigned_at")
  releasedAt DateTime? @map("released_at")
  note       String?
}

model FeePlan {
  id          String    @id @default(cuid())
  name        String
  amount      Float
  period      FeePeriod @default(Monthly)
  months      Int       @default(1)
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  payments        Payment[]
  paymentRequests PaymentRequest[]
  currentStudents Student[] @relation("CurrentFeePlan")
}

model Payment {
  id              String    @id @default(cuid())
  studentId       String    @map("student_id")
  student         Student   @relation(fields: [studentId], references: [id])
  feePlanId       String    @map("fee_plan_id")
  feePlan         FeePlan   @relation(fields: [feePlanId], references: [id])
  amount          Float
  paidAt          DateTime  @default(now()) @map("paid_at")
  validTill       DateTime? @map("valid_till")
  remainingAmount Float?    @map("remaining_amount")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
}

model PaymentRequest {
  id         String               @id @default(cuid())
  studentId  String               @map("student_id")
  student    Student              @relation(fields: [studentId], references: [id])
  feePlanId  String               @map("fee_plan_id")
  feePlan    FeePlan              @relation(fields: [feePlanId], references: [id])
  method     PaymentMethod
  status     PaymentRequestStatus @default(Pending)
  paidAmount Float?
  date       DateTime
  slipUrl    String?              @map("slip_url")
  notes      String?
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @updatedAt @map("updated_at")
}

model Complaint {
  id              String            @id @default(cuid())
  studentId       String            @map("student_id")
  student         Student           @relation(fields: [studentId], references: [id])
  title           String
  description     String
  category        ComplaintCategory @default(Other)
  status          ComplaintStatus   @default(Open)
  assignedStaffId String?           @map("assigned_staff_id")
  assignedStaff   Staff?            @relation(fields: [assignedStaffId], references: [id])
  whatsappSentAt  DateTime?         @map("whatsapp_sent_at")
  staffDoneAt     DateTime?         @map("staff_done_at")
  adminResolvedAt DateTime?         @map("admin_resolved_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
}

model VisitorLog {
  id          String    @id @default(cuid())
  studentId   String    @map("student_id")
  student     Student   @relation(fields: [studentId], references: [id])
  visitorName String    @map("visitor_name")
  relation    String?
  inAt        DateTime  @map("in_at")
  outAt       DateTime? @map("out_at")
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  user      User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(General)
  title     String
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")
}

model BedRequest {
  id           String           @id @default(cuid())
  studentId    String           @map("student_id")
  student      Student          @relation(fields: [studentId], references: [id])
  bedId        String           @map("bed_id")
  bed          Bed              @relation(fields: [bedId], references: [id])
  status       BedRequestStatus @default(Pending)
  bunkPosition String?          @map("bunk_position")  // "Top" | "Bottom" | null
  reason       String?          // required for transfer requests
  note         String?
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
}


model DirectMessage {
  id         String   @id @default(cuid())
  fromUserId String   @map("from_user_id")
  fromUser   User     @relation("SentMessages", fields: [fromUserId], references: [id])
  toUserId   String   @map("to_user_id")
  toUser     User     @relation("ReceivedMessages", fields: [toUserId], references: [id])
  message    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
}
